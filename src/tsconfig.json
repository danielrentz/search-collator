{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "..",

  // https://www.typescriptlang.org/tsconfig/#include
  "include": ["**/*.ts"],

  // https://www.typescriptlang.org/tsconfig/#compiler-options
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedDeclarations": true,
    "outDir": "../dist"
  }
}
