{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "..",

  // https://www.typescriptlang.org/tsconfig/#include
  "include": ["**/*.ts"],

  // https://www.typescriptlang.org/tsconfig/#references
  "references": [
    { "path": "../src" },
  ],

  // https://www.typescriptlang.org/tsconfig/#compiler-options
  "compilerOptions": {
    "composite": true,
    "outDir": "../output/test",
  },
}
