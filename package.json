{
  "name": "search-collator",
  "version": "1.0.0",
  "description": "Extensions for Intl.Collator for locale-aware searching in strings (findMatches, findMatch, indexOf, includes, startsWith).",
  "keywords": [
    "case-insensitive",
    "collator",
    "find",
    "includes",
    "indexof",
    "intl",
    "locale",
    "punctuation",
    "search",
    "startswith"
  ],
  "homepage": "https://github.com/danielrentz/search-collator#readme",
  "bugs": {
    "url": "https://github.com/danielrentz/search-collator/issues"
  },
  "license": "MIT",
  "author": "Daniel Rentz <daniel.rentz@gmx.de>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielrentz/search-collator.git"
  },
  "files": [
    "CHANGELOG.md",
    "dist/",
    "!dist/*.tsbuildinfo"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "coverage": "vitest run --coverage",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "prepack": "npm run build && npm run lint && npm run test",
    "test": "vitest run"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=22.18"
  }
}
