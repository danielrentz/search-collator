{
  "name": "search-collator",
  "version": "1.2.1",
  "description": "Extensions for Intl.Collator for locale-aware searching in strings (findMatches, findMatch, indexOf, lastIndexOf, includes, startsWith, endsWith).",
  "keywords": [
    "case-insensitive",
    "collator",
    "endswith",
    "find",
    "includes",
    "indexof",
    "intl",
    "lastindexof",
    "locale",
    "punctuation",
    "reverse",
    "search",
    "startswith"
  ],
  "homepage": "https://github.com/danielrentz/search-collator#readme",
  "bugs": {
    "url": "https://github.com/danielrentz/search-collator/issues"
  },
  "license": "MIT",
  "author": "Daniel Rentz <daniel.rentz@gmx.de>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielrentz/search-collator.git"
  },
  "files": [
    "CHANGELOG.md",
    "dist/",
    "!dist/*.tsbuildinfo"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsdown",
    "coverage": "vitest run --coverage",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "prepack": "npm run build && npm run lint && npm run test",
    "test": "vitest run"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.18"
  }
}
