{
  "name": "search-collator",
  "version": "1.2.1",
  "description": "Extensions for Intl.Collator for locale-aware searching in strings (findMatches, findMatch, indexOf, lastIndexOf, includes, startsWith, endsWith).",
  "keywords": [
    "case-insensitive",
    "collator",
    "endswith",
    "find",
    "includes",
    "indexof",
    "intl",
    "lastindexof",
    "locale",
    "punctuation",
    "reverse",
    "search",
    "startswith"
  ],
  "homepage": "https://github.com/danielrentz/search-collator#readme",
  "bugs": {
    "url": "https://github.com/danielrentz/search-collator/issues"
  },
  "license": "MIT",
  "author": "Daniel Rentz <daniel.rentz@gmx.de>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielrentz/search-collator.git"
  },
  "files": [
    "CHANGELOG.md",
    "dist/"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "coverage": "vitest run --coverage",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "prepack": "pnpm build",
    "test": "vitest run",
    "verify": "pnpm audit && pnpm build && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@daniel.rentz/build-tools": "^0.0.2",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "pnpm@10.33.0"
}
