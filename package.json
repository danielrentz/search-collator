{
  "name": "search-collator",
  "version": "1.0.0",
  "description": "Extensions for Intl.Collator for locale-aware searching in strings (findMatches, findMatch, indexOf, includes, startsWith).",
  "keywords": [
    "collator",
    "find",
    "includes",
    "indexof",
    "intl",
    "search",
    "startswith"
  ],
  "homepage": "https://github.com/danielrentz/search-collator#readme",
  "bugs": {
    "url": "https://github.com/danielrentz/search-collator/issues"
  },
  "license": "MIT",
  "author": "Daniel Rentz <daniel.rentz@gmx.de>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielrentz/search-collator.git"
  },
  "files": [
    "CHANGELOG.md",
    "dist/",
    "!dist/*.tsbuildinfo"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc --build",
    "clean": "premove dist",
    "coverage": "vitest run --coverage",
    "fmt": "oxfmt",
    "lint": "oxlint && oxfmt --check",
    "prepack": "npm run build && npm run lint && npm run test",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "premove": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=24"
  }
}
